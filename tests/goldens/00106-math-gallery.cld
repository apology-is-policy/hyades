@label riemann-lebesgue
    \textbf{Theorem} (Riemann-Lebesgue).
    \textit{Let $f \in L^1(\mathbb{R})$, i.e.\ $f$ is Lebesgue integrable with}

    $$\lVert f \rVert_{L^1} \coloneqq \int_{-\infty}^{\infty} |f(t)|\, dt < \infty \tag{1}$$

    \textit{Then the Fourier transform}

    $$\hat{f}(\xi) \coloneqq \int_{-\infty}^{\infty} f(t)\, e^{-2\pi i \xi t}\, dt \tag{2}$$

    \textit{satisfies}

    $$\lim_{|\xi| \to \infty} \hat{f}(\xi) = 0 \tag{RL}$$

    \textbf{Proof.} (Via density of step functions in $L^1(\mathbb{R})$.)

    \textbf{Step 1: The result for indicator functions.}
    Let $f = \mathbf{1}_{[a,b]}$ be the indicator of an interval. Then

    $$\hat{f}(\xi) = \int_a^b e^{-2\pi i \xi t}\, dt
    = \frac{e^{-2\pi i \xi b} - e^{-2\pi i \xi a}}{-2\pi i \xi}
    \qquad (\xi \neq 0) \tag{3}$$

    Taking absolute values and applying the triangle inequality:

    $$\left|\hat{f}(\xi)\right| \leq \frac{\left|e^{-2\pi i \xi b}\right|
    + \left|e^{-2\pi i \xi a}\right|}{2\pi|\xi|}
    = \frac{2}{2\pi|\xi|} = \frac{1}{\pi|\xi|} \tag{4}$$

    since $|e^{i\theta}| = 1$ for all $\theta \in \mathbb{R}$. Hence
    $\hat{f}(\xi) \to 0$ as $|\xi| \to \infty$.

    \textbf{Step 2: Extension to step functions.}
    Any step function $s = \sum_{k=1}^{N} c_k \mathbf{1}_{[a_k, b_k]}$ satisfies

    $$\left|\hat{s}(\xi)\right| \leq \sum_{k=1}^{N} |c_k|
    \cdot \frac{1}{\pi|\xi|} \xrightarrow{|\xi| \to \infty} 0 \tag{5}$$

    by linearity of the Fourier transform and Step 1 applied to each indicator.

    \textbf{Step 3: Density argument.}
    The step functions are dense in $L^1(\mathbb{R})$: for any $\varepsilon > 0$
    and any $f \in L^1(\mathbb{R})$, there exists a step function $s$ such that

    $$\lVert f - s \rVert_{L^1} < \varepsilon \tag{6}$$

    Now decompose $\hat{f}(\xi)$ using the triangle inequality:

    $$\aligned{
    \left|\hat{f}(\xi)\right|
    &= \left|\hat{f}(\xi) - \hat{s}(\xi) + \hat{s}(\xi)\right| \\
    &\leq \left|\hat{f}(\xi) - \hat{s}(\xi)\right| + \left|\hat{s}(\xi)\right| \\
    &= \left|\widehat{f - s}(\xi)\right| + \left|\hat{s}(\xi)\right|
    } \tag{7}$$

    For the first term, apply the trivial bound
    $|\hat{g}(\xi)| \leq \lVert g \rVert_{L^1}$:

    $$\left|\widehat{f - s}(\xi)\right|
    \leq \lVert f - s \rVert_{L^1} < \varepsilon \tag{8}$$

    For the second term, by Step 2, there exists $M > 0$ such that
    $|\xi| > M$ implies $|\hat{s}(\xi)| < \varepsilon$. Therefore, for all
    $|\xi| > M$:

    $$\left|\hat{f}(\xi)\right| < \varepsilon + \varepsilon = 2\varepsilon \tag{9}$$

    Since $\varepsilon > 0$ was arbitrary, $\hat{f}(\xi) \to 0$ as
    $|\xi| \to \infty$. $\square$

    \vskip{1}

    \textbf{Remark 1} (Sharpness). The conclusion cannot be strengthened to
    uniform decay: for any sequence $a_n \to 0$, there exists
    $f \in L^1(\mathbb{R})$ such that $\limsup_{|\xi| \to \infty}
    \lVert\hat{f}(\xi)\rVert / a_{|\xi|} = \infty$. In particular, one cannot
    bound the rate of decay in terms of $\lVert f \rVert_{L^1}$ alone.

    \textbf{Remark 2} (Fourier series version).
    \textit{The analogous statement holds for Fourier series: if
    $f \in L^1(\mathbb{T})$ where $\mathbb{T} = \mathbb{R}/\mathbb{Z}$, then the
    Fourier coefficients}

    $$\hat{f}(n) \coloneqq \int_0^1 f(t)\, e^{-2\pi i n t}\, dt \tag{10}$$

    \textit{satisfy $\hat{f}(n) \to 0$ as $|n| \to \infty$, $n \in \mathbb{Z}$.
    The same density proof applies, with step functions replaced by trigonometric
    polynomials.}

    \textbf{Corollary} (Plancherel). If additionally $f \in L^2(\mathbb{R})$,
    then $\hat{f} \in L^2(\mathbb{R})$ and the Fourier transform extends to a
    unitary operator on $L^2(\mathbb{R})$ satisfying

    $$\lVert\hat{f}\rVert_{L^2} = \lVert f \rVert_{L^2} \tag{11}$$

    In this setting the pointwise Riemann-Lebesgue decay is complemented by the
    global $L^2$ isometry: the transform neither concentrates nor disperses
    energy.
@end


