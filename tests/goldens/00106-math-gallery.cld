@label euler-lagrange
    \textbf{Theorem} (Euler-Lagrange).
    \textit{Let $L(q, \dot{q}, t)$ be a smooth Lagrangian, and let the action
    functional be}

    $$S[q] = \int_{t_1}^{t_2} L\!\left(q(t),\, \dot{q}(t),\, t\right) dt \tag{1}$$

    \textit{defined on smooth paths $q : [t_1, t_2] \to \mathbb{R}^n$ with fixed
    endpoints. If $q$ is a stationary point of $S$, then $q$ satisfies the}
    \textbf{Euler-Lagrange equations:}

    $$\frac{\partial L}{\partial q^i} -
    \frac{d}{dt}\frac{\partial L}{\partial \dot{q}^i} = 0
    \qquad (i = 1, \ldots, n) \tag{EL}$$

    \textbf{Proof.}

    \textbf{Step 1: Parametrising the variation.} Fix an arbitrary smooth function
    $\eta : [t_1, t_2] \to \mathbb{R}^n$ with $\eta(t_1) = \eta(t_2) = 0$ and
    define the one-parameter family

    $$q_\epsilon(t) = q(t) + \epsilon\,\eta(t), \qquad \epsilon \in \mathbb{R} \tag{2}$$

    Each $q_\epsilon$ has the same endpoints as $q$. Define

    $$\Phi(\epsilon) \coloneqq S[q_\epsilon] =
    \int_{t_1}^{t_2} L\!\left(q + \epsilon\eta,\; \dot{q} +
    \epsilon\dot{\eta},\; t\right) dt \tag{3}$$

    \textbf{Step 2: Stationarity condition.} The path $q$ is a stationary point
    of $S$ if and only if

    $$\left.\frac{d\Phi}{d\epsilon}\right|_{\epsilon=0} = 0 \qquad
    \forall\, \eta \text{ with } \eta(t_1) = \eta(t_2) = 0 \tag{4}$$

    \textbf{Step 3: Differentiating under the integral.} Since $L$ is smooth we
    may pass the derivative through the integral. By the chain rule:

    $$\frac{d\Phi}{d\epsilon} = \int_{t_1}^{t_2} \left(
    \frac{\partial L}{\partial q}\,\eta +
    \frac{\partial L}{\partial \dot{q}}\,\dot{\eta}
    \right) dt \tag{5}$$

    \textbf{Step 4: Integration by parts.} The second term involves $\dot{\eta}$.
    Setting $u = \frac{\partial L}{\partial \dot{q}}$ and $dv = \dot{\eta}\,dt$:

    $$\int_{t_1}^{t_2} \frac{\partial L}{\partial \dot{q}}\,\dot{\eta}\, dt
    = \underbrace{\left[\frac{\partial L}{\partial \dot{q}}\,\eta
    \right]_{t_1}^{t_2}}_{\displaystyle =\;0}
    \;-\; \int_{t_1}^{t_2}
    \frac{d}{dt}\!\left(\frac{\partial L}{\partial \dot{q}}\right)\eta\, dt
    \tag{6}$$

    The boundary term vanishes since $\eta(t_1) = \eta(t_2) = 0$ by construction.

    \textbf{Step 5: Collecting terms.} Substituting (6) into (5) and evaluating
    at $\epsilon = 0$ yields the key identity:

    $$\aligned{
    \left.\frac{d\Phi}{d\epsilon}\right|_{\epsilon=0}
    &= \int_{t_1}^{t_2} \frac{\partial L}{\partial q}\,\eta\, dt
    +  \int_{t_1}^{t_2} \frac{\partial L}{\partial \dot{q}}\,\dot{\eta}\, dt \\
    \intertext{Applying the integration by parts result from (6):}
    &= \int_{t_1}^{t_2} \frac{\partial L}{\partial q}\,\eta\, dt
    -  \int_{t_1}^{t_2}
    \frac{d}{dt}\!\left(\frac{\partial L}{\partial \dot{q}}\right)\eta\, dt \\
    &= \int_{t_1}^{t_2}
    \underbrace{\left(
        \frac{\partial L}{\partial q}
        - \frac{d}{dt}\frac{\partial L}{\partial \dot{q}}
    \right)}_{\displaystyle \eqqcolon\;\mathcal{E}[q]}
    \!\eta\; dt = 0
    } \tag{7}$$

    where $\mathcal{E}[q]$ denotes the \textbf{Euler-Lagrange operator} applied to $q$.

    \textbf{Step 6: Fundamental lemma.} Since (7) holds for every admissible
    $\eta$, the fundamental lemma of the calculus of variations applies: a
    continuous function $f : [t_1, t_2] \to \mathbb{R}$ satisfying

    $$\int_{t_1}^{t_2} f(t)\,\eta(t)\,dt = 0
    \qquad \forall\, \eta \in C^\infty_0(t_1, t_2) \tag{8}$$

    must satisfy $f \equiv 0$ on $[t_1, t_2]$. With $f \coloneqq \mathcal{E}[q]$,
    this gives $\mathcal{E}[q] = 0$, which is precisely (EL). $\square$

    \vskip{1}

    \textbf{Remark 1} (First integral). \textit{If $L$ does not depend explicitly
    on $q^i$ — that is, $\frac{\partial L}{\partial q^i} = 0$ — then (EL) reduces
    to $\frac{d}{dt}\frac{\partial L}{\partial \dot{q}^i} = 0$, so the generalised
    momentum}

    $$p_i \coloneqq \frac{\partial L}{\partial \dot{q}^i} \tag{9}$$

    \textit{is conserved along solutions. This is Noether's theorem in its
    simplest form.}

    \textbf{Remark 2} (Energy conservation). Define the \textbf{Hamiltonian}

    $$H \coloneqq \dot{q}^i \frac{\partial L}{\partial \dot{q}^i} - L \tag{10}$$

    (summing over $i$). Along any solution of (EL), one computes

    $$\aligned{
    \frac{dH}{dt}
    &= \ddot{q}^i \frac{\partial L}{\partial \dot{q}^i}
    + \dot{q}^i \frac{d}{dt}\frac{\partial L}{\partial \dot{q}^i}
    - \frac{dL}{dt} \\
    \intertext{Expanding $\frac{dL}{dt}$ by the chain rule and using (EL) to
    substitute $\frac{d}{dt}\frac{\partial L}{\partial \dot{q}^i} =
    \frac{\partial L}{\partial q^i}$:}
    &= \ddot{q}^i \frac{\partial L}{\partial \dot{q}^i}
    + \dot{q}^i \frac{\partial L}{\partial q^i}
    - \frac{\partial L}{\partial q^i}\dot{q}^i
    - \frac{\partial L}{\partial \dot{q}^i}\ddot{q}^i
    - \frac{\partial L}{\partial t} \\
    &= -\frac{\partial L}{\partial t}
    } \tag{11}$$

    Hence $H$ is conserved whenever $L$ has no explicit time dependence,
    $\frac{\partial L}{\partial t} = 0$.
@end

