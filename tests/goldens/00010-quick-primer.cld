    \vskip{1}
    \begin{vbox}
        \child[center]{\figlet{Feature Overview}}
        \xvskip{-1}
        \child{\hrule{/}{.}{/}}
    \end{vbox}

    \sec{Components}
    
    \fancylist{
        - Desktop executables for Mac, Linux, and Windows
          - hyades: typesets pure \hyades{} code
            - .hy extension
            - stdin/file mode
            - interactive terminal mode with a main loop
          - cassilda: \hyades{} executor/orchestrator
            - .cld extension
            - categorizes meta tages (@labels) from .cld (and other) files, and renders them where they are
              referenced -- more on that later
        - Static library with a header
        - VSCode extension
          - uses Cassilda to render @labels directly into source code comments files upon saving
          - syntax highlighting via built-in LSP
          - LSP: squiggly lines (diagnostics), hover info, go to definition, outline, auto-completion
        - Helix (hx) and Neovim (nvim) integration
          - Automatically set up by the install script
          - Syntax highlighting via a tree-sitter grammar
          - LSP (if Node is installed): Inline diagnostics, hover info, go-to, auto-completion
        - Web Application / WASM module
          - syntax highlighting via Monaco + built-in LSP
          - cassilda (pure C23) compiled into WASM
          - online rendering of cassilda notebooks (.cld files that render to itself, like
            Jupyter notebooks, for instance)
        - (optional) Julia programming language integration
          - When Julia is installed, the desktop \hyades{} enables direct interop
          via \cmd{julia}\{\}, \cmd{call}\<\>, and other commands.
    }

    \sec{Main capabilities}

    \fancylist{
        - Robust math typesetting using La/TeX syntax
          - 95\textpercent math source compatibility for LaTeX
          - Unicode or ASCII character output
          - Overridable symbol set
          - Unicode math alphabets
          - Big operators, scaling matrices
          - Aligned equations and \cmd{cases}
        - Robust prose typesetting
          - Inline math
          - Column justification with line-breaking
            - Original monospace linebreaker
        - Flex-like box layouting
          - Horizontal and vertical stacking
          - Width inheritance
          - Flex-like space distribution
          - Horizontal and vertical skips (even negative)
        - Programmability
          - Flexible and powerful user macro system
            - Conditions, registers, content measurement
            - Line post-processing
            - Most high level \hyades{} commands are written in hyades itself
          - CL: A powerful custom programming language and runtime (separate from macros)
            - Typed
            - Compiled into virtual instructions (Subnivean bytecode)
            - Executed by a stack-based virtual machine (Subnivean)
            - Drives computation for interactive/realtime terminal applications
          - Julia programming language interop
        - Table rendering
          - Custom border styles
          - Custom per-cell alignment
          - Adaptive to content
        - Markdown-like lists
          - Like this one (check out the source below)
        - ANSI escapes (color, cursor, etc.)
          - For terminal output or interactive terminal applications written in CL
        - Multi-platform
          - As a pure C program, \hyades{} can be compiled anywhere
            - Mac
            - Linux
            - Windows
            - WASM
    }


    \end{output}
@end

#before_each
    %\diagnostics{all}
    \linebreaker{greedy}
    \setwidth{72}
    \setunicode{true}
    \setmathitalic{true}
#end

#output_prefix "     "
